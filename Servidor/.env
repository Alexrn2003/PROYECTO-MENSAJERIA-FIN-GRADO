# Configuración de LDAP para el servidor de chat
# IP correcta del controlador de dominio EasyCom
LDAP_SERVER=ldap://10.0.2.15
LDAP_PORT=389
DOMAIN=easycom.local
BASE_DN=DC=easycom,DC=local

# Credenciales de administrador LDAP (para búsquedas)
# Se necesitan para obtener información de usuarios normales
LDAP_ADMIN_USER=administrador
LDAP_ADMIN_PASSWORD=Naniyalex_2003

# Configuración del servidor Flask
FLASK_ENV=development
DEBUG=False
